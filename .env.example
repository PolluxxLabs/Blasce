# ─── Database ────────────────────────────────────────────────────────────────
# PostgreSQL connection string
DATABASE_URL=postgres://user:password@localhost:5432/blasce

# ─── Authentication ───────────────────────────────────────────────────────────
# Secret key used to sign JWT tokens (any long random string)
JWT_SECRET=replace-with-a-long-random-secret

# ─── Server ───────────────────────────────────────────────────────────────────
# Port the Go API server listens on (default used by dev workflow)
PORT=8080
